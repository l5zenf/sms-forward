DATABASE_URL=sqlite://gg-guard.db?mode=rwc
SERIAL_PORT=/dev/serial/by-id/usb-EigenComm_EigenComm_Compo_000000000001-if02
BAUD_RATE=115200
WEBHOOK_URL=https://example.com/webhook
WEBHOOK_TIMEOUT_SECS=10
DEVICE_NAME=air780e
SMS_STORAGE=ME
API_ADDR=0.0.0.0:8080
# Comma-separated list of allowed CORS origins. Empty = allow any (dev only).
# Example: GG_GUARD_CORS_ORIGINS=https://sms.example.com,http://localhost:5173
GG_GUARD_CORS_ORIGINS=
# Directory of the built frontend assets (run `pnpm --dir web build` first).
GG_GUARD_WEB_DIR=web/dist
SMS_POLL_INTERVAL_SECS=2
